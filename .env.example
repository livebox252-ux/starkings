# ── Backend (Render) ─────────────────────────────────────────────────────────
# Required: your TMDB API key (get one free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Optional: PostgreSQL connection string (only needed if you add DB features)
DATABASE_URL=

# Set automatically by Render — do not set this yourself
# PORT=10000

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# The backend server root URL (no trailing slash, no /api suffix).
# Example: https://starking-api.onrender.com
VITE_API_URL=
